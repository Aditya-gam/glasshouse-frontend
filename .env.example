# Glasshouse frontend — environment contract.
# Copy to `.env.local` for local dev. Only NEXT_PUBLIC_* values are exposed to the
# browser; anything sensitive (CLERK_SECRET_KEY, DEV_USER_ID) must stay server-side
# (read solely in the DAL / route handlers).

# Base URL of the Glasshouse backend API. The generated OpenAPI client + DAL wire to
# this. Until an endpoint goes live the UI runs on fixtures/MSW, so this is optional.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Clerk auth — use the SAME instance the backend verifies JWTs against. The publishable
# key is public (ships in the client bundle); the secret key is server-only, never commit.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Dev-only backend auth fallback (server-only): before real Clerk sign-in → user-sync
# (the backend Clerk webhook) is live, the DAL sends `X-Dev-User-Id: <uuid>` for a
# seeded backend user when no Clerk token is present. Leave unset in prod.
DEV_USER_ID=
