{
  "name": "glasshouse-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spec:pull": "curl -fsS \"${NEXT_PUBLIC_API_BASE_URL:-http://localhost:8000}/openapi.json\" | python3 -m json.tool --sort-keys --indent 2 > openapi/openapi.json",
    "api:generate": "openapi-ts",
    "api:check": "openapi-ts && git diff --exit-code -- lib/api",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^7.5.9",
    "@hey-api/client-fetch": "^0.13.1",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/colors": "^3.0.0",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/otel": "^2.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "prettier": "^3.9.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
